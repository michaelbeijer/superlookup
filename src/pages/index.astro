---
import Base from '../layouts/Base.astro';
import { Image } from 'astro:assets';
import appShot from '../assets/superlookup-desktop.png';
const RELEASES = 'https://github.com/michaelbeijer/superlookup-desktop/releases/latest';
---

<Base
	title="SuperLookup – one-keystroke terminology research for translators"
	description="A free desktop app for translators: press one keystroke and research a term across all your terminology sources at once – IATE, Linguee, ProZ, Glosbe, termbases, corpora, Wikipedia and 40+ more, each in its own ad-free tab. Windows, macOS & Linux."
>
	<div class="lander">
		<section class="lander-hero">
			<div class="lander-hero-copy">
				<h1>Research multiple terminology sources with a single keystroke</h1>
				<p class="lead">
					Select a word in your CAT tool, a PDF, or an email, press one
					keystroke, and SuperLookup opens it across all your terminology
					sources at once – IATE, Linguee, ProZ, Glosbe, termbases, corpora,
					Wikipedia and 40+ more. Each in its own ad-free tab, all in one clean
					window – not scattered across your browser, with your logins remembered.
				</p>
				<div class="cta-row">
					<a class="btn-primary" href={RELEASES} target="_blank" rel="noopener">Download free ↓</a>
					<a class="btn-ghost" href="https://supervertaler.com/workbench/" rel="noopener">Or inside Supervertaler →</a>
				</div>
				<p class="platforms">Windows · macOS · Linux – no install, no account, no sign-up.</p>
			</div>

			<figure class="app-shot">
				<Image
					src={appShot}
					alt="The SuperLookup desktop app: a From/To language bar over a row of tabs – Beijerterm, IATE, Linguee, ProZ, Reverso, BabelNet, Wikipedia, Wiktionary, Wikidata, AcronymFinder – with the IATE (European Union terminology) tab open, showing entries for the Dutch word ‘trein’ with English equivalents, domain labels and reliability ratings."
					class="app-shot-img"
					widths={[720, 1200, 1687]}
					sizes="(max-width: 900px) 100vw, 860px"
					loading="eager"
				/>
			</figure>
		</section>

		<section class="how">
			<h2>How it works</h2>
			<ol>
				<li><strong>Select a term</strong> anywhere – your CAT tool, a PDF, an email, a browser.</li>
				<li><strong>Press the global hotkey</strong> (default <code>Ctrl+Alt+L</code>). SuperLookup jumps to the front, already searching it.</li>
				<li><strong>Click through the tabs</strong> – every site opens in its own embedded, ad-free view, with your login remembered and trackers blocked.</li>
			</ol>
		</section>

		<section class="features">
			<h2>Why a desktop app</h2>
			<div class="feature-grid">
				<div class="feature">
					<h3><span class="fic">⌨️</span> Global hotkey</h3>
					<p>Call it up on any selected text, from any application – no copy-paste, no alt-tabbing.</p>
				</div>
				<div class="feature">
					<h3><span class="fic">🗂️</span> 40+ resources, one place</h3>
					<p>Beijerterm, IATE, Linguee, ProZ, Glosbe, bab.la, Wikipedia, EUR-Lex, medical &amp; EU terminology and more – enable only what you use.</p>
				</div>
				<div class="feature">
					<h3><span class="fic">🚫</span> Ad-free &amp; private</h3>
					<p>An EasyList-based blocker strips ads and trackers from every tab, so the sites are cleaner than in a normal browser.</p>
				</div>
				<div class="feature">
					<h3><span class="fic">🔐</span> Logins that stick</h3>
					<p>Sign into ProZ, Juremy or Beijerterm once and stay signed in across launches.</p>
				</div>
				<div class="feature">
					<h3><span class="fic">🔎</span> Inline previews</h3>
					<p>Wikipedia, Wiktionary and Wikidata list their matching pages right inside the tab; site favicons and adjustable zoom keep it tidy.</p>
				</div>
				<div class="feature">
					<h3><span class="fic">🪶</span> Light &amp; self-contained</h3>
					<p>A single download that runs without installing anything, and lives in the system tray so the hotkey works even when the window is closed.</p>
				</div>
			</div>
		</section>

		<section class="download">
			<h2>Download</h2>
			<div class="dl-row">
				<a class="dl-pill" href={RELEASES} target="_blank" rel="noopener">🪟 Windows</a>
				<a class="dl-pill" href={RELEASES} target="_blank" rel="noopener">🍎 macOS</a>
				<a class="dl-pill" href={RELEASES} target="_blank" rel="noopener">🐧 Linux</a>
			</div>
			<p class="dl-note">
				Each build is self-contained (~150–210 MB) and starts in a couple of
				seconds. New to it? Read the <a href="/help">quick help</a>. SuperLookup
				also comes built into the
				<a href="https://supervertaler.com/workbench/" rel="noopener">Supervertaler Workbench</a>,
				alongside your own termbases and translation memories.
			</p>
		</section>
	</div>
</Base>
