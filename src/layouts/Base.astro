---
import '../styles/superlookup.css';

interface Props {
	title?: string;
	description?: string;
}
const {
	title = 'SuperLookup — one search box for a translator’s reference web',
	description = 'Type once, search a whole shelf of terminology and reference resources — Superterm, IATE, Linguee, ProZ, Juremy, BabelNet, Wikipedia and more.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" href="/favicon.ico" sizes="any" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
	</head>
	<body>
		<header class="site-head">
			<a class="wordmark" href="/">SuperLookup</a>
			<nav class="site-tools">
				<a href="https://github.com/michaelbeijer/superlookup-desktop/releases/latest" rel="noopener">Desktop app ↓</a>
				<a href="https://superterm.io" rel="noopener">Superterm</a>
				<a href="https://supervertaler.com" rel="noopener">Supervertaler</a>
			</nav>
		</header>

		<main>
			<slot />
		</main>

		<footer class="site-foot">
			<p>
				<strong>SuperLookup</strong> — a one-box search across a translator’s
				reference web, by
				<a href="https://beijer.uk" rel="noopener">Michael Beijer</a>. Also a
				free
				<a href="https://github.com/michaelbeijer/superlookup-desktop/releases/latest" rel="noopener">desktop app</a>
				(each site in its own ad-free tab, plus a global hotkey — Windows,
				macOS &amp; Linux), or built into
				<a href="https://supervertaler.com" rel="noopener">Supervertaler</a>
				alongside your own local termbases and translation memories.
			</p>
		</footer>
	</body>
</html>
