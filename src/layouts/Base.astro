---
import '../styles/superlookup.css';

interface Props {
	title?: string;
	description?: string;
}
const {
	title = 'SuperLookup – one-keystroke terminology research for translators',
	description = 'A free desktop app for translators: press one keystroke and research a term across all your terminology sources at once, each in its own ad-free tab.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" href="/favicon.ico" sizes="any" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
	</head>
	<body>
		<header class="site-head">
			<a class="wordmark" href="/">SuperLookup</a>
			<nav class="site-tools">
				<a href="https://github.com/michaelbeijer/superlookup-desktop/releases/latest" rel="noopener">Download ↓</a>
				<a href="/help">Help</a>
				<a href="https://superterm.io" rel="noopener">Superterm</a>
				<a href="https://supervertaler.com" rel="noopener">Supervertaler</a>
			</nav>
		</header>

		<main>
			<slot />
		</main>

		<footer class="site-foot">
			<p>
				<strong>SuperLookup</strong> – research a term across all your
				terminology sources at once, in one window, by
				<a href="https://beijer.uk" rel="noopener">Michael Beijer</a>. A free
				<a href="https://github.com/michaelbeijer/superlookup-desktop/releases/latest" rel="noopener">desktop app</a>
				(each site in its own ad-free tab, plus a global hotkey – Windows,
				macOS &amp; Linux), or built into the
				<a href="https://supervertaler.com" rel="noopener">Supervertaler Workbench</a>
				alongside your own local termbases and translation memories.
			</p>
		</footer>
	</body>
</html>
