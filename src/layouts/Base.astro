---
import '../styles/superlookup.css';

interface Props {
	title?: string;
	description?: string;
}
const {
	title = 'SuperLookup – one-keystroke terminology research for translators',
	description = 'A free desktop app for translators: press one keystroke and research a term across all your terminology sources at once, each in its own ad-free tab.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" href="/favicon.ico?v=2" sizes="any" />
		<link rel="icon" type="image/png" href="/favicon.png?v=2" sizes="48x48" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
	</head>
	<body>
		<header class="site-head">
			<a class="wordmark" href="/" title="SuperLookup home">SuperLookup</a>
			<button class="nav-toggle" aria-label="Menu" aria-expanded="false" aria-controls="site-nav">
				<span class="nav-toggle-bar"></span>
				<span class="nav-toggle-bar"></span>
				<span class="nav-toggle-bar"></span>
			</button>
			<nav class="site-tools" id="site-nav">
				<a href="https://github.com/michaelbeijer/superlookup-desktop/releases/latest"
					target="_blank" rel="noopener"
					title="Download the free desktop app – Windows, macOS or Linux">Download ↓</a>
				<a href="/help" title="How to install and use SuperLookup: the hotkey, managing your searches, and more">Help</a>
				<a href="https://beijerterm.com" target="_blank" rel="noopener"
					title="Beijerterm – a curated multilingual terminology database (and a built-in SuperLookup resource)">Beijerterm</a>
				<a href="https://supervertaler.com" target="_blank" rel="noopener"
					title="Supervertaler – an AI-enhanced CAT tool ecosystem, with SuperLookup built in">Supervertaler</a>
				<a href="https://beijer.uk" target="_blank" rel="noopener"
					title="Beijer.uk – Michael Beijer, patent translator and the maker of SuperLookup">Beijer.uk</a>
			</nav>
		</header>

		<main>
			<slot />
		</main>

		<footer class="site-foot">
			<p>
				<strong>SuperLookup</strong> – research a term across all your
				terminology sources at once, in one window, by
				<a href="https://beijer.uk" rel="noopener">Michael Beijer</a>. A free
				<a href="https://github.com/michaelbeijer/superlookup-desktop/releases/latest" rel="noopener">desktop app</a>
				(each site in its own ad-free tab, plus a global hotkey – Windows,
				macOS &amp; Linux), or built into the
				<a href="https://supervertaler.com/workbench/" rel="noopener">Supervertaler Workbench</a>
				alongside your own local termbases and translation memories.
			</p>
		</footer>

		<script>
			const navToggle = document.querySelector('.nav-toggle');
			const siteNav = document.getElementById('site-nav');
			if (navToggle && siteNav) {
				navToggle.addEventListener('click', () => {
					const open = siteNav.classList.toggle('open');
					navToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
				});
				// Tapping a link closes the menu again.
				siteNav.querySelectorAll('a').forEach((a) =>
					a.addEventListener('click', () => {
						siteNav.classList.remove('open');
						navToggle.setAttribute('aria-expanded', 'false');
					}),
				);
			}
		</script>
	</body>
</html>
